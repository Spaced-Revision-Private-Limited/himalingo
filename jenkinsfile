pipeline {
  agent any

  stages {

    stage('Clone Check') {
      steps {
        echo 'Code pulled from GitHub successfully'
        sh 'ls'
      }
    }

    stage('Frontend Build') {
      steps {
        dir('frontend') {
          sh 'echo Installing frontend dependencies'
          sh 'npm install'
          sh 'echo Building frontend'
          sh 'npm run build'
        }
      }
    }

    stage('Backend Setup') {
      steps {
        dir('backend') {
          sh 'echo Installing backend dependencies'
          sh 'pip3 install -r requirements.txt || true'
          sh 'echo Backend ready'
        }
      }
    }

  }
}
