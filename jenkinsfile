pipeline {
  agent any

  stages {

    stage('Check Code') {
      steps {
        echo 'Code pulled'
        sh 'ls'
      }
    }

    stage('Frontend Build') {
      steps {
        dir('frontend') {
          sh 'npm install'
          sh 'npm run build'
        }
      }
    }

    stage('Backend Install') {
      steps {
        dir('backend') {
          sh 'pip3 install -r requirements.txt'
        }
      }
    }

  }
}
